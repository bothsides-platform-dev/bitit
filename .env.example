# Supabase Transaction Pooler URL (port 6543, pgbouncer 모드)
# Settings → Database → Connection string → Transaction 탭
DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Test Postgres (docker compose pg-test profile). 로컬 통합 테스트 전용.
DATABASE_URL_TEST=postgres://bidit:bidit@localhost:5433/bidit_test

# Auth.js v5 JWT signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Resend API key for transactional email (invitations, verify, notifications).
RESEND_API_KEY=
# Resend 발신자 주소. Resend 대시보드에서 인증된 도메인의 주소여야 함.
RESEND_FROM=send@bidit.store

# 국세청 사업자등록 상태조회 service key (data.go.kr)
NTS_SERVICE_KEY=

# Public-facing origin (emailed links, redirects)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://[project-ref].supabase.co
# Supabase service_role key (Settings → API → service_role). 서버 사이드 전용.
SUPABASE_SERVICE_ROLE_KEY=

# Storage backend: 'supabase' | 미설정(로컬 디스크, 개발용)
STORAGE_BACKEND=supabase

# Sentry DSN (sentry.io → Settings → Projects → [project] → Client Keys)
NEXT_PUBLIC_SENTRY_DSN=https://[key]@o[org-id].ingest.sentry.io/[project-id]
# Sentry DSN — 서버/Edge 런타임 전용. 없으면 NEXT_PUBLIC_SENTRY_DSN 사용.
SENTRY_DSN=
# Sentry org/project slugs for source map upload
SENTRY_ORG=
SENTRY_PROJECT=
# Sentry Auth Token (sentry.io → Settings → Auth Tokens). CI/배포 시 필요.
SENTRY_AUTH_TOKEN=

# 채널톡(Channel.io). Plugin Key는 Desk → 채널 설정 → 일반 → SDK 탭에서 확인.
NEXT_PUBLIC_CHANNEL_IO_PLUGIN_KEY=
# 채널톡 Secure mode HMAC secret. Desk → 채널 설정 → 보안 → 사용자 데이터 암호화 활성화 시 발급.
# 미설정 시 식별만 하고 hash 생략(개발 모드 동작).
CHANNEL_IO_SECRET=
