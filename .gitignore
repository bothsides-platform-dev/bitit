# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local file storage (Step 11 LocalStorage). Prod swaps to S3/Supabase Storage.
/uploads
# e2e UPLOAD_DIR (Step 14 Playwright config) — wiped between runs.
/uploads-e2e

# Playwright artifacts (Step 14)
/test-results
/playwright-report
/playwright/.cache

# drizzle: keep migrations + meta committed (history + snapshots).

# Sentry Config File
.env.sentry-build-plugin
